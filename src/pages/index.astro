---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="jrgmadrid"
  description="personal site. senior dev between things. building yomiko."
>
  <main class="hero">
    <div class="hero__top">
      <h1 class="hero__title">jrgmadrid.</h1>
      <p class="hero__deck">building in public is <span class="hero__accent">cringe</span> but then again so am i.</p>
    </div>

    <div class="hero__bottom">
      <p class="hero__footer">
        <a href="https://github.com/jrgmadrid">github.com/jrgmadrid</a> · <a href="/feed.xml">/feed.xml</a> · senior dev between things, vancouver. building <a href="https://github.com/jrgmadrid/yomiko">yomiko</a>.
      </p>

      <figure class="hero__signature">
        <svg viewBox="0 0 400 225" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="yuasa-frame-title">
          <title id="yuasa-frame-title">abstract three-band rendering of yuasa's riverside frame: deep purple sky, twilight horizon band, deeper purple river, and one warm light point at the horizon.</title>
          <rect x="0" y="0" width="400" height="135" fill="oklch(18% 0.06 285)" />
          <rect x="0" y="135" width="400" height="25" fill="oklch(38% 0.095 285)" />
          <rect x="0" y="160" width="400" height="65" fill="oklch(22% 0.075 285)" />
          <circle cx="280" cy="148" r="3" fill="oklch(72% 0.17 25)" />
        </svg>
        <figcaption class="hero__signature-caption">yuasa, riverside.</figcaption>
      </figure>
    </div>
  </main>
</Layout>

<style>
  .hero {
    min-height: 100vh;
    padding: clamp(var(--space-2xl), 6vw, var(--space-4xl)) var(--container-padding);
    display: flex;
    flex-direction: column;
    background: var(--color-purple-deep);
    color: var(--color-ink-on-purple);
    box-sizing: border-box;
  }

  .hero__title {
    font-family: var(--font-headline);
    font-style: italic;
    font-weight: 800;
    font-size: clamp(5rem, 14vw, 14rem);
    line-height: 0.9;
    letter-spacing: -0.06em;
    margin: 0 0 var(--space-lg) -0.06em;
    color: var(--color-ink-on-purple);
  }

  .hero__deck {
    font-family: var(--font-deck);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 3.2vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-ink-on-purple-muted);
    max-width: 24ch;
    margin: 0;
  }

  .hero__accent {
    color: var(--color-warm-ribbon);
  }

  .hero__bottom {
    margin-top: auto;
    padding-top: var(--space-4xl);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-2xl);
  }

  .hero__footer {
    flex: 1;
    font-family: var(--font-mono);
    font-size: var(--text-small);
    line-height: var(--leading-body);
    color: var(--color-ink-on-purple-muted);
    margin: 0;
    max-width: 64ch;
  }

  .hero__signature {
    width: clamp(80px, 10vw, 140px);
    flex-shrink: 0;
    margin: 0;
    padding: 0;
    text-align: right;
  }

  .hero__signature svg {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--color-grid-on-purple);
  }

  .hero__signature-caption {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-ink-on-purple-faint);
    letter-spacing: 0.02em;
    margin: var(--space-xs) 0 0;
    line-height: 1.4;
  }

  @media (max-width: 767px) {
    .hero {
      padding: var(--space-2xl) var(--container-padding);
    }

    .hero__title {
      font-size: clamp(3.5rem, 16vw, 6rem);
    }

    .hero__deck {
      font-size: clamp(1.25rem, 5vw, 1.75rem);
      max-width: none;
    }

    .hero__bottom {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: var(--space-lg);
    }

    .hero__signature {
      width: clamp(100px, 30vw, 160px);
      align-self: flex-start;
      text-align: left;
    }
  }
</style>
